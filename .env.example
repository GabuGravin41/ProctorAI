# ─── ProctorAI — Root Environment Variables ────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# VITE_ prefix is REQUIRED for variables to be available in the browser bundle.
# Never commit .env — it is gitignored.
# ────────────────────────────────────────────────────────────────────────────

# ── Clerk Authentication (https://dashboard.clerk.com) ──────────────────────
# Development keys start with pk_test_ / sk_test_
# Production keys start with pk_live_ / sk_live_  ← use these on Vercel
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
