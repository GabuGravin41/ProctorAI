# Production Environment Variables for Vercel
# Copy this file to .env.production or set these in Vercel dashboard

# Database - Use Neon PostgreSQL
DATABASE_URL=postgresql://user:password@host.neon.tech/database?sslmode=require

# Clerk Authentication
CLERK_PUBLISHABLE_KEY=pk_live_your_key_here
CLERK_SECRET_KEY=sk_live_your_key_here
CLERK_PROXY_URL=https://your-domain.com/auth

# OpenRouter AI API (for question generation)
OPENROUTER_API_KEY=sk_or_your_key_here

# Server Port (Vercel sets this automatically, but include for clarity)
PORT=3000
