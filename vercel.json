{
  "version": 2,
  "buildCommand": "pnpm run build:prod",
  "installCommand": "pnpm install",
  "outputDirectory": "artifacts/proctor-ai/dist/public",
  "functions": {
    "artifacts/api-server/api/index.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/artifacts/api-server/api/index"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
